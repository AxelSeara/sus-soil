---
import {
  fetchPostsByCategory,
  isEventLikePost,
  toNewsCard,
  WP_CATEGORY_IDS,
} from '../../lib/wp';

let newsCards = [];
let eventCards = [];

try {
  const posts = await fetchPostsByCategory(WP_CATEGORY_IDS.NEWS);
  const sorted = [...posts].sort((a, b) => new Date(b?.date || 0).getTime() - new Date(a?.date || 0).getTime());

  newsCards = sorted
    .filter((post) => !isEventLikePost(post))
    .slice(0, 3)
    .map(toNewsCard);

  eventCards = sorted
    .filter((post) => isEventLikePost(post))
    .slice(0, 3)
    .map(toNewsCard);
} catch (error) {
  newsCards = [];
  eventCards = [];
}

const formatDate = (value) => {
  const d = new Date(value || '');
  if (Number.isNaN(d.getTime())) return '';
  return d.toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' });
};
---

<section class="content-shell section-shell py-12 sm:py-14 lg:py-16">
  <div class="card-elevated my-4 p-5 sm:p-6 lg:p-8">
    <div class="mb-6 flex items-center justify-between gap-4">
      <h2 class="text-3xl font-medium font-serif text-brown md:text-4xl">News</h2>
      <a href="/news" class="inline-flex items-center gap-2 rounded-full border border-brown px-5 py-2 text-brown transition-colors hover:bg-brown hover:text-white">
        Visit all
      </a>
    </div>
    <div class="mb-8 h-px bg-gradient-to-r from-transparent via-darkGreen/30 to-transparent"></div>

    {newsCards.length ? (
      <div class="grid grid-cols-1 gap-5 md:grid-cols-3 md:gap-6">
        {newsCards.map((card) => (
          <article class="group overflow-hidden rounded-2xl border border-darkGreen/10 bg-white p-5 shadow-md transition-all duration-300 hover:-translate-y-0.5 hover:shadow-xl">
            <div class="mb-3 flex items-center gap-2">
              <span class="meta-chip">News</span>
              <time class="text-xs text-gray-500" dateTime={card.date || undefined}>{formatDate(card.date)}</time>
            </div>

            <h3 class="mb-3 text-xl font-serif font-semibold leading-tight text-brown">
              <a href={card.linkPath} class="hover:underline">{card.title}</a>
            </h3>

            {card.imageUrl ? (
              <img
                src={card.imageUrl}
                alt={card.imageAlt || card.title}
                class="mb-4 h-40 w-full rounded-xl object-cover"
                loading="lazy"
                decoding="async"
              />
            ) : (
              <div class="mb-4 flex h-40 items-center justify-center rounded-xl bg-gray-100 text-xs text-gray-500">No image</div>
            )}

            <p class="mb-4 text-sm leading-relaxed text-gray-700">{card.excerpt.slice(0, 140)}{card.excerpt.length > 140 ? '…' : ''}</p>
            <a href={card.linkPath} class="text-sm font-medium text-darkGreen hover:underline">Read article →</a>
          </article>
        ))}
      </div>
    ) : (
      <p class="text-sm text-brown/70">No news available right now.</p>
    )}
  </div>

  <div class="mx-auto my-8 w-24 border-t-2 border-darkGreen" aria-hidden="true"></div>

  <div class="card-elevated my-4 p-5 sm:p-6 lg:p-8">
    <div class="mb-6 flex items-center justify-between gap-4">
      <h2 class="text-3xl font-medium font-serif text-brown md:text-4xl">Events</h2>
      <a href="/news?filter=events" class="inline-flex items-center gap-2 rounded-full border border-brown px-5 py-2 text-brown transition-colors hover:bg-brown hover:text-white">
        Visit all
      </a>
    </div>
    <div class="mb-8 h-px bg-gradient-to-r from-transparent via-darkGreen/30 to-transparent"></div>

    {eventCards.length ? (
      <div class="grid grid-cols-1 gap-5 md:grid-cols-3 md:gap-6">
        {eventCards.map((card) => (
          <article class="group overflow-hidden rounded-2xl border border-darkGreen/10 bg-white p-5 shadow-md transition-all duration-300 hover:-translate-y-0.5 hover:shadow-xl">
            <div class="mb-3 flex items-center gap-2">
              <span class="meta-chip">Event</span>
              <time class="text-xs text-gray-500" dateTime={card.date || undefined}>{formatDate(card.date)}</time>
            </div>

            <h3 class="mb-3 text-xl font-serif font-semibold leading-tight text-brown">
              <a href={card.linkPath} class="hover:underline">{card.title}</a>
            </h3>

            {card.imageUrl ? (
              <img
                src={card.imageUrl}
                alt={card.imageAlt || card.title}
                class="mb-4 h-40 w-full rounded-xl object-cover"
                loading="lazy"
                decoding="async"
              />
            ) : (
              <div class="mb-4 flex h-40 items-center justify-center rounded-xl bg-gray-100 text-xs text-gray-500">No image</div>
            )}

            <p class="mb-4 text-sm leading-relaxed text-gray-700">{card.excerpt.slice(0, 140)}{card.excerpt.length > 140 ? '…' : ''}</p>
            <a href={card.linkPath} class="text-sm font-medium text-darkGreen hover:underline">Read article →</a>
          </article>
        ))}
      </div>
    ) : (
      <p class="text-sm text-brown/70">No events available right now.</p>
    )}
  </div>
</section>
