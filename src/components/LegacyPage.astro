---
import BaseLayout from '../layouts/BaseLayout.astro';
import LegacyRouteRenderer from '../astro/LegacyRouteRenderer.jsx';

const {
  title,
  description,
  canonicalPath,
  keywords,
  image,
  type,
  noindex,
  structuredData,
  path = Astro.url.pathname,
  hydrate = 'idle',
} = Astro.props;
---
<BaseLayout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  keywords={keywords}
  image={image}
  type={type}
  noindex={noindex}
  structuredData={structuredData}
>
  {hydrate === 'load' ? (
    <LegacyRouteRenderer path={path} client:load />
  ) : hydrate === 'visible' ? (
    <LegacyRouteRenderer path={path} client:visible />
  ) : (
    <LegacyRouteRenderer path={path} client:idle />
  )}
</BaseLayout>
