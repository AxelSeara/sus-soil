---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchPostsByCategory, WP_CATEGORY_IDS, toNewsletterItem } from '../../lib/wp';

let posts = [];
try {
  const raw = await fetchPostsByCategory(WP_CATEGORY_IDS.NEWSLETTER);
  posts = raw
    .map(toNewsletterItem)
    .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
} catch (error) {
  posts = [];
}

const subscribeUrl =
  'https://gmail.us11.list-manage.com/subscribe?u=6fbd6e1c74aa5e4a311896dcc&id=826cb744b4';
---
<BaseLayout
  title="Newsletter | SUS-SOIL"
  description="Read the latest SUS-SOIL newsletters and project updates."
  canonicalPath="/resources/newsletter"
>
  <section class="bg-gradient-to-b from-white via-[#f6fcf7] to-[#edf8f1] py-20 px-4">
    <div class="max-w-screen-xl mx-auto grid grid-cols-1 lg:grid-cols-[1fr_400px] gap-12 items-start text-brown">
      <div class="flex flex-col">
        <h1 class="text-4xl md:text-5xl font-bold font-serif mb-6">Newsletter</h1>
        <p class="text-lg leading-relaxed mb-10">
          Stay up to date with our latest news and project milestones.
        </p>

        <h2 class="text-2xl font-bold font-serif mb-4">Newsletter Archive</h2>

        {posts.length ? (
          <ul class="space-y-12">
            {posts.map((post) => (
              <li class="max-w-md rounded-2xl border border-darkGreen/10 bg-white/70 p-4 shadow-[0_12px_30px_-24px_rgba(20,66,38,0.7)]">
                {post.imageUrl ? <img src={post.imageUrl} alt={post.imageAlt || post.title} class="w-full aspect-square object-cover rounded-xl mb-4" loading="lazy" /> : null}
                <a href={post.url} target="_blank" rel="noopener noreferrer" class="text-2xl font-semibold hover:underline hover:text-brown transition-colors">
                  {post.title}
                </a>
                <p class="text-sm text-gray-500 mt-1">{post.date ? new Date(post.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }) : ''}</p>
                {post.excerptHtml ? <div class="mt-3 text-base text-brown/80" set:html={post.excerptHtml} /> : null}
              </li>
            ))}
          </ul>
        ) : (
          <p class="text-gray-500 italic">No newsletter issues available.</p>
        )}
      </div>

      <aside class="bg-white/90 rounded-2xl shadow-[0_18px_34px_-24px_rgba(20,66,38,0.7)] p-6 border border-darkGreen/10 sticky top-20 self-start">
        <h3 class="text-2xl font-serif font-semibold mb-4">Join Our Mailing List</h3>
        <p class="text-sm text-brown mb-6">Click the button below to sign up and receive project updates.</p>
        <a href={subscribeUrl} target="_blank" rel="noopener noreferrer" class="inline-block bg-darkGreen hover:bg-darkGreen/90 text-white font-semibold px-6 py-3 rounded-full text-center transition-colors">
          Subscribe Now
        </a>
      </aside>
    </div>
  </section>
</BaseLayout>
