---
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  extractAcfFile,
  fetchMediaByParent,
  fetchPostsByCategory,
  fileExtensionFromMime,
  toMaterialItem,
  WP_CATEGORY_IDS,
} from '../../lib/wp';

let items = [];
try {
  const posts = await fetchPostsByCategory(WP_CATEGORY_IDS.PRACTICE_ABSTRACTS);
  items = await Promise.all(
    posts.map(async (post) => {
      const base = toMaterialItem(post);
      let file = extractAcfFile(post?.acf || {});

      if (!file.url) {
        const attachments = await fetchMediaByParent(post.id);
        const pdf = attachments.find((m) => m?.mime_type === 'application/pdf');
        if (pdf?.source_url) {
          file = {
            url: pdf.source_url,
            mime: pdf.mime_type || 'application/pdf',
            title: pdf.title?.rendered || '',
          };
        }
      }

      return {
        ...base,
        file,
      };
    })
  );
} catch (error) {
  items = [];
}
---
<BaseLayout
  title="Practice Abstracts | SUS-SOIL"
  description="Explore SUS-SOIL practice abstracts and applied insights for sustainable soil management."
  canonicalPath="/resources/practice-abstracts"
>
  <section class="max-w-screen-xl mx-auto px-4 py-16 text-brown">
    <h1 class="text-4xl md:text-5xl font-bold font-serif mb-10 text-center">Practice Abstracts</h1>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {items.length ? (
        items.map((item) => {
          const extension = fileExtensionFromMime(item.file?.mime);
          return (
            <article class="bg-white p-4 rounded-xl border border-gray-200 shadow-sm hover:shadow-md transition-shadow duration-300 h-full flex flex-col">
              <div class="relative w-full rounded-lg overflow-hidden mb-4 bg-gray-100 aspect-square">
                {item.imageUrl ? (
                  <img src={item.imageUrl} alt={item.imageAlt || item.title} class="w-full h-full object-cover" loading="lazy" />
                ) : (
                  <div class="w-full h-full flex items-center justify-center text-red-700 text-sm">PDF</div>
                )}
                {item.file?.mime ? <span class="absolute top-2 left-2 text-[11px] px-2 py-1 rounded-full bg-white/90 backdrop-blur border border-black/5">{extension}</span> : null}
              </div>

              <h2 class="text-lg font-semibold leading-snug min-h-[3.5rem]">{item.title}</h2>
              <p class="text-xs text-gray-500 mt-0.5">Uploaded: {item.date ? new Date(item.date).toLocaleDateString() : 'N/A'}</p>

              {item.file?.url ? (
                <a href={item.file.url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 bg-brown text-white px-4 py-2 rounded-lg hover:bg-darkGreen transition-colors mt-auto">
                  Download ({extension})
                </a>
              ) : (
                <span class="inline-flex items-center justify-center px-4 py-2 rounded-lg bg-gray-100 text-gray-500 text-sm mt-auto">File coming soon</span>
              )}
            </article>
          );
        })
      ) : (
        <p class="col-span-full text-center text-gray-500 py-6">No practice abstracts available at the moment.</p>
      )}
    </div>
  </section>
</BaseLayout>
