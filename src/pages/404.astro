---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Page Not Found | SUS-SOIL"
  description="The requested page could not be found."
  canonicalPath="/404"
  noindex={true}
>
  <section class="content-shell section-shell py-16 text-center">
    <h1 class="text-3xl md:text-4xl font-bold text-brown mb-4">Page Not Found</h1>
    <p class="text-brown/80 mb-6">The page you are looking for does not exist or has moved.</p>
    <a href="/" class="inline-block rounded-full bg-brown px-5 py-2.5 text-white font-semibold hover:bg-brown/90">Back to Home</a>
  </section>
</BaseLayout>
